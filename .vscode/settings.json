{
  "C_Cpp.default.browse.limitSymbolsToIncludedHeaders": true,
  "C_Cpp.errorSquiggles": "Disabled",
  "C_Cpp.files.exclude": {
    "**/.git": true,
    ".pio/build": true,
    ".pio/libdeps": true
  },
  "C_Cpp.intelliSenseCacheSize": 128,
  "C_Cpp.intelliSenseEngine": "Disabled",
  "C_Cpp.workspaceParsingPriority": "low",
  "C_Cpp.workspaceSymbols": "Just My Code",
  "files.exclude": {
    "**/*.pyc": true,
    "**/.git": true,
    "**/__pycache__": true,
    ".pio/build": true,
    ".pio/libdeps": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.pio/**": true,
    "**/__pycache__/**": true,
    "**/node_modules/**": true,
    ".pio/**": true
  },
  "javascript.suggest.autoImports": false,
  "javascript.validate.enable": false,
  "platformio-ide.autoRebuildAutocompleteIndex": true,
  "platformio-ide.activateProjectOnTextEditorChange": true,
  "search.exclude": {
    "**/*.pyc": true,
    "**/.git": true,
    "**/.pio/**": true,
    "**/__pycache__": true,
    "**/node_modules/**": true,
    ".pio/**": true
  },
  "typescript.disableAutomaticTypeAcquisition": true,
  "typescript.suggest.autoImports": false,
  "typescript.tsserver.maxTsServerMemory": 512,
  "typescript.tsserver.useSeparateSyntaxServer": false,
  "typescript.validate.enable": false
}
